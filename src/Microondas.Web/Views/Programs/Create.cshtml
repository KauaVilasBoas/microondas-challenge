@model CreateProgramViewModel
@{
    ViewData["Title"] = "Novo Programa Customizado";
}

<h1>Criar Programa Customizado</h1>

@if (Model.ErrorMessage != null)
{
    <div class="alert alert-error">@Model.ErrorMessage</div>
}

<form asp-action="Create" asp-controller="Programs" method="post">
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label asp-for="Name">Nome do Programa</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="validation-error"></span>
    </div>

    <div class="form-group">
        <label asp-for="Food">Alimento</label>
        <input asp-for="Food" class="form-control" />
        <span asp-validation-for="Food" class="validation-error"></span>
    </div>

    <div class="form-group">
        <label asp-for="TimeInSeconds">Tempo (segundos)</label>
        <input asp-for="TimeInSeconds" type="number" min="1" max="120" class="form-control" />
        <span asp-validation-for="TimeInSeconds" class="validation-error"></span>
    </div>

    <div class="form-group">
        <label asp-for="Power">Potência (1-10)</label>
        <input asp-for="Power" type="number" min="1" max="10" class="form-control" />
        <span asp-validation-for="Power" class="validation-error"></span>
    </div>

    <div class="form-group">
        <label asp-for="HeatingChar">Caractere de Aquecimento</label>
        <input asp-for="HeatingChar" maxlength="1" class="form-control" />
        <small>Deve ser único. Não pode ser "." nem caracteres de programas existentes.</small>
        <span asp-validation-for="HeatingChar" class="validation-error"></span>
    </div>

    <div class="form-group">
        <label asp-for="Instructions">Instruções (opcional)</label>
        <textarea asp-for="Instructions" rows="4" class="form-control"></textarea>
        <span asp-validation-for="Instructions" class="validation-error"></span>
    </div>

    <div class="button-group">
        <button type="submit" class="btn btn-primary">Salvar</button>
        <a href="/Programs" class="btn btn-secondary">Cancelar</a>
    </div>
</form>
