@model HeatingStatusViewModel
@{
    var statusStr = Model.Status ?? "Idle";
    var statusClass = "status-" + statusStr.ToLower();

    string StatusLabel(string s) => s switch
    {
        "Running" => "▶ AQUECENDO",
        "Paused" => "⏸ PAUSADO",
        "Completed" => "✓ CONCLUÍDO",
        "Cancelled" => "✕ CANCELADO",
        _ => "◯ AGUARDANDO"
    };
}

<div class="display-panel @statusClass" id="displayPanel">
    <div class="status-led">
        <span class="led-dot"></span>
        <span id="status-label">@StatusLabel(statusStr)</span>
    </div>
    <div id="time-display">@(Model.DisplayTime ?? (Model.RemainingSeconds?.ToString() ?? "0"))</div>
    <div id="power-display">POTÊNCIA: @(Model.PowerLevel?.ToString() ?? "—")</div>
    <div class="output-display" id="output-display">@(Model.CurrentOutput ?? "")</div>
</div>
