@model HeatingViewModel
@{
    ViewData["Title"] = "Micro-ondas Digital";
    var status = ViewData["HeatingStatus"] as HeatingStatusViewModel;
    var programs = ViewData["Programs"] as IReadOnlyList<ProgramReadModel> ?? [];

    var statusStr = status?.Status ?? "Idle";
    var statusClass = "status-" + statusStr.ToLower();

    string StatusLabel(string s) => s switch {
        "Running"   => "▶ AQUECENDO",
        "Paused"    => "⏸ PAUSADO",
        "Completed" => "✓ CONCLUÍDO",
        "Cancelled" => "✕ CANCELADO",
        _           => "◯ AGUARDANDO"
    };
}

<div class="microwave-container">
    <h1>Micro-ondas Digital</h1>

    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-error">@Model.ErrorMessage</div>
    }

    <!-- LCD Display Panel -->
    <div class="display-panel @statusClass" id="displayPanel">
        <div class="status-led">
            <span class="led-dot"></span>
            <span id="status-label">@StatusLabel(statusStr)</span>
        </div>
        <div id="time-display">@(status?.DisplayTime ?? "0")</div>
        <div id="power-display">POTÊNCIA: @(status?.PowerLevel?.ToString() ?? "—")</div>
        <div class="output-display" id="output-display">@(status?.CurrentOutput ?? "")</div>
    </div>

    <!-- Control Panel -->
    <div class="control-panel">
        <!-- Input form (time + power) -->
        <form id="startForm" asp-action="Start" asp-controller="Heating" method="post">
            @Html.AntiForgeryToken()
            <div class="controls-grid">
                <div class="control-block">
                    <div class="input-group">
                        <label for="TimeInSeconds">Tempo (segundos)</label>
                        <input type="number" id="TimeInSeconds" name="TimeInSeconds"
                               min="1" max="120" placeholder="1–120"
                               value="@Model.TimeInSeconds" />
                    </div>
                    <vc:digital-keyboard target-field-id="TimeInSeconds" />
                </div>

                <div class="control-block">
                    <div class="input-group">
                        <label for="PowerLevel">Potência (1-10)</label>
                        <input type="number" id="PowerLevel" name="PowerLevel"
                               min="1" max="10" placeholder="1–10"
                               value="@Model.PowerLevel" />
                    </div>
                    <vc:digital-keyboard target-field-id="PowerLevel" />
                </div>
            </div>
        </form>

        <!-- Action buttons (outside form, linked via form= attribute) -->
        <div class="action-bar">
            <button type="submit" form="startForm" class="btn btn-start">
                @(status?.IsRunning == true ? "▶ +30s"
                    : status?.IsPaused == true ? "▶ Retomar"
                    : "▶ Iniciar")
            </button>

            <form asp-action="PauseOrCancel" asp-controller="Heating" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-secondary">
                    @(status?.IsRunning == true ? "⏸ Pausar"
                        : status?.IsPaused == true ? "✕ Cancelar"
                        : "✕ Limpar")
                </button>
            </form>
        </div>
    </div>

    <!-- Heating Programs -->
    @if (programs.Count > 0)
    {
        <div class="programs-section">
            <div class="section-header">
                <h2>Programas de Aquecimento</h2>
            </div>
            <form asp-action="StartProgram" asp-controller="Heating" method="post">
                @Html.AntiForgeryToken()
                <div class="program-list">
                    @foreach (var program in programs)
                    {
                        <label class="program-item @(program.IsCustom ? "program-custom" : "")">
                            <input type="radio" name="SelectedProgramId" value="@program.Id" />
                            <span class="program-name">@program.Name</span>
                            <span class="program-food">@program.Food</span>
                            <span class="program-details">
                                @(program.TimeInSeconds / 60)min @(program.TimeInSeconds % 60)s
                                · Pot @program.Power
                                · '@program.HeatingChar'
                            </span>
                            @if (program.Instructions != null)
                            {
                                <small class="program-instructions">@program.Instructions</small>
                            }
                        </label>
                    }
                </div>
                <button type="submit" class="btn btn-program">▶ Iniciar Programa</button>
            </form>
        </div>
    }
</div>
