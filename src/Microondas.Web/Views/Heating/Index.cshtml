@model HeatingViewModel
@{
    ViewData["Title"] = "Micro-ondas Digital";

    // Status is passed by the controller solely to drive the action-button labels.
    // The LCD display is rendered by HeatingDisplayViewComponent (self-fetches via MediatR).
    var status    = ViewData["HeatingStatus"] as HeatingStatusViewModel;
    var isRunning = status?.IsRunning  == true;
    var isPaused  = status?.IsPaused   == true;
}

<div class="microwave-container">
    <h1>Micro-ondas Digital</h1>

    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-error">@Model.ErrorMessage</div>
    }

    @* LCD Display — renderizado pelo HeatingDisplayViewComponent (busca status via MediatR) *@
    @await Component.InvokeAsync("HeatingDisplay")

    @* Painel de controle: inputs de tempo/potência + botões de ação *@
    <div class="control-panel">
        <form id="startForm" asp-action="Start" asp-controller="Heating" method="post">
            @Html.AntiForgeryToken()
            <div class="controls-grid">
                <div class="control-block">
                    <div class="input-group">
                        <label for="TimeInSeconds">Tempo (segundos)</label>
                        <input type="number" id="TimeInSeconds" name="TimeInSeconds"
                               min="1" max="120" placeholder="1–120"
                               value="@Model.TimeInSeconds" />
                    </div>
                    @await Component.InvokeAsync("DigitalKeyboard", new { targetFieldId = "TimeInSeconds" })
                </div>

                <div class="control-block">
                    <div class="input-group">
                        <label for="PowerLevel">Potência (1-10)</label>
                        <input type="number" id="PowerLevel" name="PowerLevel"
                               min="1" max="10" placeholder="1–10"
                               value="@Model.PowerLevel" />
                    </div>
                    @await Component.InvokeAsync("DigitalKeyboard", new { targetFieldId = "PowerLevel" })
                </div>
            </div>
        </form>

        <div class="action-bar">
            <button type="submit" form="startForm" class="btn btn-start">
                @(isRunning ? "▶ +30s" : isPaused ? "▶ Retomar" : "▶ Iniciar")
            </button>

            <form asp-action="PauseOrCancel" asp-controller="Heating" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-secondary">
                    @(isRunning ? "⏸ Pausar" : isPaused ? "✕ Cancelar" : "✕ Limpar")
                </button>
            </form>
        </div>
    </div>

    @* Seletor de programas — renderizado pelo ProgramSelectorViewComponent (busca via MediatR) *@
    @await Component.InvokeAsync("ProgramSelector")
</div>
